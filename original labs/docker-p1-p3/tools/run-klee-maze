#!/usr/bin/env bash
set -euo pipefail

cd "${1:-/work/projects/3}"
rm -rf klee-out-* klee-last maze-sym.o maze-sym.bc

if command -v llvm-gcc.cde >/dev/null 2>&1 && ! command -v clang-11 >/dev/null 2>&1; then
  llvm-gcc.cde -I"$KLEE_INCLUDE" --emit-llvm -c -g maze-sym.c
  klee.cde maze-sym.o
else
  cc="${CLANG:-}"
  if [[ -z "$cc" ]]; then
    cc="$(command -v clang-11 || command -v clang || true)"
  fi
  if [[ -z "$cc" ]]; then
    echo "clang not found" >&2
    exit 1
  fi
  "$cc" -D'sleep(x)=0' -I"$KLEE_INCLUDE" -emit-llvm -c -g -O0 -Xclang -disable-O0-optnone maze-sym.c -o maze-sym.bc
  klee maze-sym.bc
fi
